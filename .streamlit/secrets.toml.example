# Copy this file to .streamlit/secrets.toml for local dev, or paste these
# key/value pairs into the Streamlit Community Cloud "Secrets" panel for
# the deployed app. NEVER commit the real secrets.toml.

ANTHROPIC_API_KEY = "sk-ant-..."

# Fusion JDBC fields are local-only (no JVM in Streamlit Cloud).
# Leave commented unless you actually run with a JVM available.
# FUSION_HOST        = "your-pod.fa.ocs.oraclecloud.com"
# FUSION_USERNAME    = "your.username"
# FUSION_PASSWORD    = "your-password"
# FUSION_REPORT_PATH = "/~your_user/path/RP_ARB.xdo"
